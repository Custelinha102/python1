while True:
    try:
        n = int(input("Digite um número inteiro positivo: "))
        if n > 0:
            break
        else:
            print("Digite um número positivo.")
    except ValueError:
        print("Digite apenas números.")

soma = 0
i = 1

while i <= n:
    if i % 2 == 0:
        soma = soma + i
    i = i + 1

print("Soma dos números pares:", soma)